    class PetShop
    {
        public Cat[] Cats = new Cat[3];
        public Dog[] Dogs = new Dog[3];
        public Bird[] Birds = new Bird[3];
        public Fish[] Fishes = new Fish[3];
        public void RemoveByNickName(string nickname)
        {
            for (int i = 0; i < Cats.Length; i++)
            {
                if (Cats[i] != null && Cats[i].Nickname == nickname)
                {
                    Cats[i] = null;
                }
            }

            for (int i = 0; i < Dogs.Length; i++)
            {
                if (Dogs[i] != null && Dogs[i].Nickname == nickname)
                {
                    Dogs[i] = null;
                }
            }

            for (int i = 0; i < Birds.Length; i++)
            {
                if (Birds[i] != null && Birds[i].Nickname == nickname)
