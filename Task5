    class Animal
    {
        public string Nickname { get; set; }
        public int Age { get; set; }
        public string Gender { get; set; }
        public int Energy { get; set; }
        public double Price { get; set; }
        public double MealQuantity { get; set; }
        public virtual void Eat(double mealQuantity) { }
        public virtual void Sleep() {}
        public virtual void Play() {}
    }

    class Cat : Animal
    {
        public override void Eat(double mealQuantity)
        {
            MealQuantity += mealQuantity;
            Energy += 20;
            Price += 20;
            Console.WriteLine($"{Nickname} yemək yedi");
        }

        public override void Sleep()
        {
            Energy += 50;
            Console.WriteLine($"{Nickname} yatır");
        }

        public override void Play()
        {
            Energy -= 25;
            Console.WriteLine($"{Nickname} oynayır");
            if (Energy <= 0)
            {
                Energy = 0;
                Console.WriteLine();
                Console.WriteLine($"{Nickname} yatmaqa getdi");
                Sleep();
            }
        }
    }


