                    Birds[i] = null;
                }
            }

            for (int i = 0; i < Fishes.Length; i++)
            {
                if (Fishes[i] != null && Fishes[i].Nickname == nickname)
                {
                    Fishes[i] = null;
                }
            }
        }

        public double TotalMeal()
        {
            double total = 0;
            for (int i = 0; i < Cats.Length; i++)
            {
                if (Cats[i] != null)
                    total += Cats[i].MealQuantity;
            }
            return total;
        }

        public double TotalCatPrice()
        {
            double total = 0;
            for (int i = 0; i < Cats.Length; i++)
            {
                if (Cats[i] != null)
                    total += Cats[i].Price;
            }
            return total;
        }
        public double TotalDogPrice()
        {
            double total = 0;
